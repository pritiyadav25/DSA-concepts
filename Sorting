    public static boolean checkarryissorted(int arr[] ){
        int n= arr.length-1;
        for(int i=0;i<n;i++){
            if(arr[i]>arr[i+1]){
                return false;
            }
            
        }
        return true;
        
    }
    public static void main(String args[]){
        int arr[]={2,1,4,5,3,6};
        boolean result= checkarryissorted(arr);
        System.out.print(result);
    }
    
    }

